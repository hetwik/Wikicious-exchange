# ════════════════════════════════════════════════════════════════════════════
#  WIKICIOUS V5 — Environment Variables
#  Copy this file to .env and fill in real values before deploying.
#  NEVER commit .env to git — it's in .gitignore already.
# ════════════════════════════════════════════════════════════════════════════

# ── DEPLOYER ──────────────────────────────────────────────────────────────
# Private key of the wallet used to deploy contracts and sign keeper txs
DEPLOYER_PRIVATE_KEY=0x...

# ── RPC ENDPOINTS ─────────────────────────────────────────────────────────
# Get free RPC URLs from: Alchemy, Infura, QuickNode, or public endpoints

ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WS_URL=wss://arb1.arbitrum.io/ws
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com
BNB_RPC_URL=https://bsc-dataseed.binance.org
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Testnets
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
OP_SEPOLIA_RPC=https://sepolia.optimism.io
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ── BLOCK EXPLORER API KEYS (for contract verification) ───────────────────
ARBISCAN_KEY=
ETHERSCAN_KEY=
OPTIMISMSCAN_KEY=
BASESCAN_KEY=
POLYGONSCAN_KEY=
BSCSCAN_KEY=

# ── KEEPER SERVICE ─────────────────────────────────────────────────────────
# Hot wallet for keeper operations (oracle updates, liquidations, gas rebates)
# Fund with ~0.1 ETH on each chain for gas
KEEPER_PRIVATE_KEY=0x...
KEEPER_ADDRESS=0x...
KEEPER_TICK_MS=5000
KEEPER_HEALTH_PORT=8081

# Pyth oracle keeper — pushes price updates before trades
# Uses the same key as KEEPER_PRIVATE_KEY by default
WIKI_ORACLE_ADDRESS=         # Filled automatically after deploy

# Gas rebate keeper
WIKI_GAS_REBATE_ADDRESS=     # Filled automatically after deploy
WIKI_BUYBACK_ADDRESS=        # Filled automatically after deploy

# ── GUARDIAN (multi-sig signer for oracle exotic pairs) ───────────────────
GUARDIAN_PRIVATE_KEY=0x...
GUARDIAN_ADDRESS=0x...

# ── FRONTEND ──────────────────────────────────────────────────────────────
REACT_APP_API_URL=https://api.wikicious.io
REACT_APP_WS_URL=wss://api.wikicious.io/ws
REACT_APP_WALLETCONNECT_PROJECT_ID=   # Get from cloud.walletconnect.com

# Contract addresses — filled automatically by deploy.js into deployments.arbitrum.json
# These are read by the frontend at runtime from /api/contracts endpoint
REACT_APP_WIK_TOKEN=
REACT_APP_WIKI_ORACLE=
REACT_APP_WIKI_VAULT=
REACT_APP_WIKI_PERP=
REACT_APP_MARKET_REGISTRY=
REACT_APP_WIKI_ORDERBOOK=
REACT_APP_STAKING=
REACT_APP_LENDING=
REACT_APP_BRIDGE=
REACT_APP_CROSSCHAIN_ROUTER=
REACT_APP_CROSSCHAIN_LENDING=
REACT_APP_SPOT_ROUTER=
REACT_APP_LAUNCHPAD=
REACT_APP_LAUNCHPOOL=
REACT_APP_LP=
REACT_APP_LIQUID_STAKING=
REACT_APP_FEE_DISTRIBUTOR=
REACT_APP_LIQUIDATOR=
REACT_APP_KEEPER_REGISTRY=
REACT_APP_GMX_BACKSTOP=
REACT_APP_FLASH_LOAN=
REACT_APP_MARGIN_LOAN=
REACT_APP_LP_COLLATERAL=
REACT_APP_MEV_HOOK=
REACT_APP_REBALANCER=
REACT_APP_WIKI_SOCIAL=
REACT_APP_SOCIAL_REWARDS=
REACT_APP_PROP_POOL=
REACT_APP_PROP_EVAL=
REACT_APP_PROP_FUNDED=
REACT_APP_YIELD_SLICE=
REACT_APP_YIELD_AGGREGATOR=

# ── BACKEND API ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
DB_PATH=./data/wikicious.db
JWT_SECRET=                  # Min 32 chars, generate with: openssl rand -hex 32
ADMIN_PIN=                   # 6-digit PIN for admin dashboard

# ── EXTERNAL DATA FEEDS ────────────────────────────────────────────────────
# Forex rates for WikiForexOracle guardian prices (exotic pairs)
CURRENCYLAYER_KEY=           # Get from currencylayer.com (free tier: 1000 req/mo)
# Alternative: FIXER_API_KEY= from fixer.io

# CoinGecko for spot price fallbacks
COINGECKO_API_KEY=           # Optional, free tier has rate limits

# ── LAYERZERO V5 ───────────────────────────────────────────────────────────
# LZ endpoint is the same on all EVM chains: 0x1a44076050125825900e736c501f859c50fE728c
# No API key needed — purely on-chain. After deploying on all chains, run:
# node contracts/scripts/register_lz_peers.js

# ── PYTH NETWORK ──────────────────────────────────────────────────────────
# Pyth is pull-based — no API key needed for Hermes public endpoint
# Hermes URL: https://hermes.pyth.network
# Pyth contract on Arbitrum: 0xff1a0f4744e8582DF1aE09D5611b887B6a12925C

# ── SECURITY ──────────────────────────────────────────────────────────────
ALERT_EMAIL=                 # Email for critical alerts (oracle down, large liquidation etc.)
SECURITY_WEBHOOK_URL=        # Slack/Discord webhook for security monitor alerts
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=200

# ── ARWEAVE (optional — for on-chain storage of trade proofs) ─────────────
ARWEAVE_KEY=                 # Arweave wallet JSON key (optional)
BUNDLR_URL=https://node1.bundlr.network
BUNDLR_PUB_KEY=

# ── COPY TRADING SERVICE ───────────────────────────────────────────────────
COPY_SERVICE_PORT=4001       # Internal microservice port

# ── MULTI-SIG (WikiTimelockController + WikiMultisigGuard) ────────────────
# These addresses are set at deploy time. Update after deploying to each chain.
MULTISIG_SIGNER_1=           # Required signer 1
MULTISIG_SIGNER_2=           # Required signer 2
MULTISIG_SIGNER_3=           # Optional signer 3 (for 3-of-3 config)

# ── FUNDING INTERVAL ──────────────────────────────────────────────────────
FUNDING_INTERVAL=28800       # 8 hours in seconds (standard perp funding rate)

# ── DEPLOYMENT OUTPUT ─────────────────────────────────────────────────────
# deploy.js writes contract addresses here after deployment
# contracts/deployments.arbitrum.json
# contracts/deployments.optimism.json
# contracts/deployments.base.json
# contracts/deployments.polygon.json
