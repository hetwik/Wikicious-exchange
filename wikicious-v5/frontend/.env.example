# ════════════════════════════════════════════════════════════
#  WIKICIOUS FRONTEND — Environment Variables
#  Copy to .env and fill in all values before npm run build
# ════════════════════════════════════════════════════════════

# ── Chain ───────────────────────────────────────────────────
REACT_APP_CHAIN_ID=42161
REACT_APP_API_URL=https://api.wikicious.io
REACT_APP_WS_URL=wss://api.wikicious.io/ws

# ── WalletConnect ───────────────────────────────────────────
# Get from: https://cloud.walletconnect.com → Create Project
REACT_APP_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ── Alchemy RPC ─────────────────────────────────────────────
# Get from: https://dashboard.alchemy.com
REACT_APP_ALCHEMY_KEY=your_alchemy_api_key_here

# ── Fiat On-Ramp API Keys ───────────────────────────────────
# MoonPay: https://dashboard.moonpay.com → API Keys
# Apply as business partner → get pk_live_... key (not test key)
REACT_APP_MOONPAY_API_KEY=pk_live_your_moonpay_key

# Transak: https://partner.transak.com → API Keys
# Apply as partner → get production API key
REACT_APP_TRANSAK_API_KEY=your_transak_production_key

# Banxa: https://banxa.com/partners → contact sales@banxa.com
REACT_APP_BANXA_PARTNER_ID=wikicious

# Ramp: https://ramp.network/business → API Keys
REACT_APP_RAMP_API_KEY=your_ramp_api_key

# ── Deployed Contract Addresses ─────────────────────────────
# Copy from contracts/deployments.arbitrum.json after deploy
REACT_APP_WIK_TOKEN=
REACT_APP_WIKI_ORACLE=
REACT_APP_WIKI_VAULT=
REACT_APP_WIKI_PERP=
REACT_APP_WIKI_SPOT=
REACT_APP_WIKI_STAKING=
REACT_APP_WIKI_LENDING=
REACT_APP_WIKI_BRIDGE=
REACT_APP_MARKET_REGISTRY=
REACT_APP_ORDERBOOK=
REACT_APP_GMX_BACKSTOP=
REACT_APP_SPOT_ROUTER=
REACT_APP_KEEPER_REGISTRY=
REACT_APP_LIQUIDATOR=
REACT_APP_FLASH_LOAN=
REACT_APP_MARGIN_LOAN=
REACT_APP_LP_COLLATERAL=
REACT_APP_CROSSCHAIN_LENDING=
REACT_APP_CROSSCHAIN_ROUTER=
REACT_APP_PROP_EVAL=
REACT_APP_PROP_FUNDED=
REACT_APP_PROP_POOL=
REACT_APP_PROP_CHALLENGE=
REACT_APP_REVENUE_SPLITTER=
