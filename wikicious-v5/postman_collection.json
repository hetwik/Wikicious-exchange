    {
      "name": "Trading",
      "item": [
        {
          "name": "Place Market Order - Long",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200,201]));",
            "pm.test('Has tx or orderId', () => { const d = pm.response.json(); pm.expect(d.txHash || d.orderId || d.positionId).to.exist; });"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/trade/order",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"marketIndex\":0,\"isLong\":true,\"collateral\":\"100000000\",\"leverage\":5,\"orderType\":\"market\"}" }
          }
        },
        {
          "name": "Place Limit Order",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200,201]));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/trade/order",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"marketIndex\":0,\"isLong\":true,\"collateral\":\"100000000\",\"leverage\":3,\"orderType\":\"limit\",\"limitPrice\":\"48000000000000000000000\"}" }
          }
        },
        {
          "name": "Get My Positions",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Positions array', () => pm.expect(pm.response.json().positions).to.be.an('array'));",
            "pm.test('Positions have required fields', () => { const ps = pm.response.json().positions; if (ps.length > 0) { pm.expect(ps[0]).to.have.property('id'); pm.expect(ps[0]).to.have.property('symbol'); pm.expect(ps[0]).to.have.property('isLong'); pm.collectionVariables.set('position_id', ps[0].id); } });"
          ]}}],
          "request": { "method": "GET", "url": "{{base_url}}/api/trade/positions/{{wallet}}" }
