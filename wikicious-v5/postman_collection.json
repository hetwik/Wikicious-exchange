          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/bots",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"type\":\"grid\",\"symbol\":\"BTCUSDT\",\"marketIndex\":0,\"wallet\":\"{{wallet}}\",\"config\":{\"lowerPrice\":45000,\"upperPrice\":55000,\"gridCount\":10,\"totalCapital\":500,\"leverage\":2}}" }
          }
