          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/copy/subscribe",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"masterAddress\":\"0x6666666666666666666666666666666666666666\",\"wallet\":\"{{wallet}}\",\"copyRatio\":1.0,\"maxTradeSize\":100,\"copySl\":true,\"copyTp\":true}" }
          }
