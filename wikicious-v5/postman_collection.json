{
  "info": {
    "name": "Wikicious Exchange API",
    "description": "Complete API test suite for Wikicious perpetuals exchange. Run against http://localhost:3001 or https://api.wikicious.io",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "4.0.0"
  },
  "variable": [
    { "key": "base_url",   "value": "http://localhost:3001" },
    { "key": "jwt_token",  "value": "" },
    { "key": "wallet",     "value": "0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045" },
    { "key": "bot_id",     "value": "" },
    { "key": "sub_id",     "value": "" },
    { "key": "position_id","value": "" }
