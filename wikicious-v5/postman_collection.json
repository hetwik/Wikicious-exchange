          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/bots",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"type\":\"macd\",\"symbol\":\"ETHUSDT\",\"marketIndex\":1,\"wallet\":\"{{wallet}}\",\"config\":{\"tradeSize\":100,\"leverage\":5,\"fastPeriod\":12,\"slowPeriod\":26,\"signalPeriod\":9,\"stopLossPct\":2}}" }
          }
