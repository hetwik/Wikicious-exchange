          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Bots array', () => pm.expect(pm.response.json().bots).to.be.an('array'));",
            "pm.test('Has created bot', () => pm.expect(pm.response.json().bots.length).to.be.gte(1));"
          ]}}],
