  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Has token', () => { const d = pm.response.json(); pm.expect(d.token).to.be.a('string'); pm.collectionVariables.set('jwt_token', d.token); });"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/register",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"email\":\"test@wikicious.io\",\"password\":\"Test123!@#\",\"username\":\"testtrader\",\"wallet\":\"{{wallet}}\"}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has token', () => { const d = pm.response.json(); pm.expect(d.token).to.be.a('string'); pm.collectionVariables.set('jwt_token', d.token); });",
            "pm.test('Has user object', () => { const d = pm.response.json(); pm.expect(d.user).to.have.property('id'); });"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/login",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"email\":\"test@wikicious.io\",\"password\":\"Test123!@#\"}" }
          }
        },
        {
          "name": "Get Me (auth required)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has wallet', () => pm.expect(pm.response.json().wallet_address).to.be.a('string'));"
          ]}}],
          "request": { "method": "GET", "url": "{{base_url}}/api/auth/me" }
        },
        {
          "name": "Login - wrong password",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/login",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\"email\":\"test@wikicious.io\",\"password\":\"wrongpass\"}" }
          }
        }
      ]
    },
    {
      "name": "Markets",
      "item": [
        {
          "name": "Get All Markets",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Markets array', () => { const d = pm.response.json(); pm.expect(d.markets).to.be.an('array').with.length.greaterThan(0); });",
            "pm.test('BTCUSDT exists', () => { const d = pm.response.json(); pm.expect(d.markets.some(m => m.symbol === 'BTCUSDT')).to.be.true; });",
            "pm.test('Market has required fields', () => { const m = pm.response.json().markets[0]; pm.expect(m).to.have.all.keys(['symbol','price','change24h','volume24h','openInterest']); });"
          ]}}],
          "request": { "method": "GET", "url": "{{base_url}}/api/markets/all" }
        },
        {
          "name": "Get Market by ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has price', () => pm.expect(pm.response.json().price).to.be.a('string'));"
          ]}}],
          "request": { "method": "GET", "url": "{{base_url}}/api/markets/0" }
        },
