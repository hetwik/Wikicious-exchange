# ════════════════════════════════════════════════════════════════
#  WIKICIOUS CONTRACTS — Environment Configuration
#  Copy this file:  cp .env.example .env
#  Never commit .env to git.
# ════════════════════════════════════════════════════════════════


# ── DEPLOYER WALLET (required) ──────────────────────────────────
# This wallet pays for gas during deployment (~0.2–0.3 ETH needed).
# Use a FRESH wallet — retire it after deployment is complete.
# NEVER reuse this key for keeper or guardian wallets.

DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY


# ── TREASURY WALLET (required for ownership transfer) ───────────
# This becomes the owner of all contracts after transfer-ownership.js.
# Use a hardware wallet (Ledger/Trezor) for maximum security.
# Run after deploy: npx hardhat run scripts/transfer-ownership.js --network arbitrum

TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET_ADDRESS


# ── ARBITRUM RPC (required) ─────────────────────────────────────
# Get a free key at: https://dashboard.alchemy.com
# → Create App → Arbitrum One → copy the HTTPS URL

ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY


# ── ARBISCAN API KEY (required for contract verification) ────────
# Required to verify contracts on arbiscan.io (makes source code public).
# Sign up free: https://arbiscan.io/register → My API Keys

ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY


# ── CONTRACT ADDRESSES ──────────────────────────────────────────
# Leave blank before first deploy.
# The deploy script fills these automatically and saves to:
#   contracts/deployments.arbitrum.json
# Copy values from there into backend/.env and frontend/.env

WIK_TOKEN_ADDRESS=
WIKI_ORACLE_ADDRESS=
WIKI_VAULT_ADDRESS=
WIKI_PERP_ADDRESS=
MARKET_REGISTRY_ADDRESS=
FOREX_ORACLE_ADDRESS=
WIKI_SOCIAL_ADDRESS=
WIKI_SOCIAL_REWARDS_ADDRESS=
PROP_POOL_ADDRESS=
PROP_EVAL_ADDRESS=
PROP_FUNDED_ADDRESS=
WIKI_BONUS_ADDRESS=
GMX_BACKSTOP_ADDRESS=
SPOT_ROUTER_ADDRESS=

# ── Revenue wallet addresses ────────────────────────────────────────────────
# Set to your hardware wallet addresses BEFORE deploying.
# These receive protocol revenue automatically. Keep private.
OPS_WALLET=0xYOUR_OPS_HARDWARE_WALLET_ADDRESS
RESERVE_WALLET=0xYOUR_RESERVE_HARDWARE_WALLET_ADDRESS
