PORT=3001
NODE_ENV=development
JWT_SECRET=wikicious-testnet-dev-secret-change-on-mainnet
DB_PATH=./data/wikicious-testnet.db

# Alchemy (Arbitrum Sepolia) — get at https://dashboard.alchemy.com
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY_HERE
RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE
WS_RPC_URL=wss://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# ── Keeper wallets (testnet only — use throwaway keys) ──────────
# Get test ETH from https://faucet.arbitrum.io
KEEPER_PRIVATE_KEY=0xYOUR_TESTNET_KEEPER_KEY
GUARDIAN_PRIVATE_KEY=0xYOUR_TESTNET_GUARDIAN_KEY

# ── Contract addresses (fill after testnet deploy) ──────────────
# Run: cd contracts && npx hardhat run scripts/deploy.js --network arbitrumSepolia
WIKI_VAULT_ADDRESS=
WIKI_PERP_ADDRESS=
WIKI_AMM_ADDRESS=
WIKI_SPOT_ADDRESS=
WIKI_ORACLE_ADDRESS=
WIKI_FOREX_ORACLE_ADDRESS=
WIKI_MARKET_REGISTRY_ADDRESS=
WIK_TOKEN_ADDRESS=
WIKI_SOCIAL_ADDRESS=
WIKI_SOCIAL_REWARDS_ADDRESS=
WIKI_PROP_POOL_ADDRESS=
WIKI_PROP_EVAL_ADDRESS=
WIKI_PROP_FUNDED_ADDRESS=
WIKI_BONUS_ADDRESS=
WIKI_GMX_BACKSTOP_ADDRESS=
WIKI_SPOT_ROUTER_ADDRESS=

# ── External API keys ───────────────────────────────────────────
OPENEXCHANGERATES_KEY=YOUR_KEY_HERE
CURRENCYLAYER_KEY=YOUR_KEY_HERE
PINATA_JWT=YOUR_JWT_HERE

# ── Bot engine ──────────────────────────────────────────────────
MAX_BOTS_PER_USER=10
MAX_CUSTOM_BOTS=3

# ── Arbiscan (for contract verification) ───────────────────────
ARBISCAN_API_KEY=YOUR_KEY_HERE
