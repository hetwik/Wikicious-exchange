# ════════════════════════════════════════════════════════════
#  WIKICIOUS BACKEND — Environment Variables
# ════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
JWT_SECRET=generate_64_char_random_hex_here

# ── Database ────────────────────────────────────────────────
# Supabase: https://supabase.com → New Project → Connection String
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DB_PATH=./data/wikicious.db

# ── Redis ───────────────────────────────────────────────────
# Upstash: https://upstash.com → Create Database → REST URL
REDIS_URL=redis://default:password@xxx.upstash.io:6379

# ── Blockchain ──────────────────────────────────────────────
# Alchemy: https://dashboard.alchemy.com
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Keeper Bot Wallet ────────────────────────────────────────
# This wallet submits keeper transactions (liquidations, oracle updates)
# NOT your Safe wallet — this is a hot wallet for keeper bots only
# Fund with 0.01 ETH for gas. Private key only in this file, never commit.
KEEPER_PRIVATE_KEY=0x_keeper_wallet_private_key
GUARDIAN_PRIVATE_KEY=0x_guardian_wallet_private_key

# ── Contract Addresses ───────────────────────────────────────
# Copy ALL from contracts/deployments.arbitrum.json after deploy
WIKI_PERP_ADDRESS=
WIKI_VAULT_ADDRESS=
WIKI_ORACLE_ADDRESS=
WIKI_STAKING_ADDRESS=
WIKI_LENDING_ADDRESS=
WIKI_MARKET_REGISTRY_ADDRESS=
WIKI_LIQUIDATOR_ADDRESS=
WIKI_KEEPER_REGISTRY_ADDRESS=
WIKI_REVENUE_SPLITTER_ADDRESS=
WIKI_PROP_EVAL_ADDRESS=
WIKI_PROP_POOL_ADDRESS=
WIKI_PROP_FUNDED_ADDRESS=
